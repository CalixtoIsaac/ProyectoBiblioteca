<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.biblioteca_1.ui.ResumenController"
      spacing="20">

    <!-- Fila 1: Libros y Usuarios -->
    <HBox spacing="16">

        <!-- Card Libros -->
        <VBox style="-fx-background-color: #FEFCF7; -fx-background-radius: 10; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(44,24,16,0.12), 10, 0, 0, 2);"
              spacing="8" HBox.hgrow="ALWAYS">
            <Label text="LIBROS" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7A6652;"/>
            <Label fx:id="lblTotalLibros" text="--"
                   style="-fx-font-family: 'Georgia'; -fx-font-size: 44px; -fx-font-weight: bold; -fx-text-fill: #B8860B;"/>
            <Label text="titulos registrados" style="-fx-font-size: 12px; -fx-text-fill: #7A6652;"/>
            <Separator/>
            <Label fx:id="lblLibrosDisponibles" text="--"
                   style="-fx-font-size: 12px; -fx-text-fill: #4A6741; -fx-font-weight: bold;"/>
        </VBox>

        <!-- Card Usuarios -->
        <VBox style="-fx-background-color: #FEFCF7; -fx-background-radius: 10; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(44,24,16,0.12), 10, 0, 0, 2);"
              spacing="8" HBox.hgrow="ALWAYS">
            <Label text="USUARIOS" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7A6652;"/>
            <Label fx:id="lblTotalUsuarios" text="--"
                   style="-fx-font-family: 'Georgia'; -fx-font-size: 44px; -fx-font-weight: bold; -fx-text-fill: #2C1810;"/>
            <Label text="usuarios registrados" style="-fx-font-size: 12px; -fx-text-fill: #7A6652;"/>
            <Separator/>
            <HBox spacing="16">
                <VBox spacing="2">
                    <Label text="Lectores" style="-fx-font-size: 11px; -fx-text-fill: #7A6652;"/>
                    <Label fx:id="lblTotalLectores" text="--"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #4A6741;"/>
                </VBox>
                <VBox spacing="2">
                    <Label text="Administradores" style="-fx-font-size: 11px; -fx-text-fill: #7A6652;"/>
                    <Label fx:id="lblTotalAdmins" text="--"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #B8860B;"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Card Préstamos -->
        <VBox style="-fx-background-color: #FEFCF7; -fx-background-radius: 10; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(44,24,16,0.12), 10, 0, 0, 2);"
              spacing="8" HBox.hgrow="ALWAYS">
            <Label text="PRESTAMOS" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7A6652;"/>
            <Label fx:id="lblPrestamosActivos" text="--"
                   style="-fx-font-family: 'Georgia'; -fx-font-size: 44px; -fx-font-weight: bold; -fx-text-fill: #5C3317;"/>
            <Label text="prestamos activos" style="-fx-font-size: 12px; -fx-text-fill: #7A6652;"/>
            <Separator/>
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="Total historico:" style="-fx-font-size: 11px; -fx-text-fill: #7A6652;"/>
                <Label fx:id="lblPrestamosHistorico" text="--"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2C1810;"/>
            </HBox>
        </VBox>

    </HBox>

    <!-- Estado del sistema -->
    <VBox style="-fx-background-color: #FEFCF7; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(44,24,16,0.08), 8, 0, 0, 2);"
          spacing="6">
        <Label text="ESTADO DEL SISTEMA" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7A6652;"/>
        <Label fx:id="lblEstado" text="Cargando..."
               style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
    </VBox>

</VBox>